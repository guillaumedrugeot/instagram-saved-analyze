# ── Required ──────────────────────────────────────────────────────────────────

# LLM provider: mistral | gemini | openai | claude
LLM_PROVIDER=mistral

# API key for the chosen provider
LLM_API_KEY=your_api_key_here

# Browser where you are logged into Instagram: brave | chrome | firefox
INSTAGRAM_BROWSER=brave

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Model to use (defaults per provider: mistral-small-latest / gemini-2.0-flash / gpt-4o-mini / claude-sonnet-4-6)
# LLM_MODEL=mistral-small-latest

# Where to write the Markdown notes
# OUTPUT_DIR=~/Documents/ReelNotes

# Max reels to process per daily run
# DAILY_LIMIT=10

# What topic to filter for (used verbatim in the triage prompt)
# TOPIC=AI, machine learning, or AI-powered tools
